# ───────────────────────────────────────────────────────────────────────────
# Frontend .env  →  положить в КОРЕНЬ репозитория  front/
# ───────────────────────────────────────────────────────────────────────────

# Базовый URL бэкенда. Пусто → фронт проксирует /api на localhost:8000
# через встроенный Vite dev-прокси (CORS не нужен).
VITE_API_BASE_URL=

# API-ключ (заголовок X-API-Key). В dev бэк разрешает пустой (auth выключен).
VITE_API_KEY=
